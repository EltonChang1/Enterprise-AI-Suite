PORT=4100
NODE_ENV=development
DEFAULT_TENANT=demo-enterprise

AUTH_MODE=hybrid
JWT_SECRET=replace-me
JWT_ISSUER=enterprise-ai-suite
JWT_AUDIENCE=enterprise-api
JWT_TTL=8h

OIDC_ISSUER_URL=
OIDC_AUDIENCE=

DATABASE_URL=postgres://postgres:postgres@localhost:5432/enterprise_ai_suite
PG_SSL=false
RUN_MIGRATIONS_ON_START=true

REDIS_URL=redis://localhost:6379
JOBS_QUEUE_NAME=enterprise-jobs

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5178/billing/success
STRIPE_CANCEL_URL=http://localhost:5178/billing/cancel

OTEL_ENABLED=true
OTEL_SERVICE_NAME=enterprise-ai-suite-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
